{
  "name": "meteo-synop-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:data": "node scripts/build-cache.js",
    "update:data": "node scripts/update-synop.js",
    "update:noaa": "node scripts/update-noaa-ghcn.js",
    "update:all": "node scripts/update-synop.js && node scripts/update-noaa-ghcn.js",
    "deploy": "bash scripts/deploy.sh",
    "install:systemd": "bash scripts/install-systemd.sh",
    "start": "node server.js",
    "dev": "node server.js",
    "dev:watch": "node --watch --watch-path=server.js --watch-path=scripts server.js"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0"
  }
}
